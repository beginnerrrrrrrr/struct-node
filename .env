# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's listed in .gitignore.

# From: github.com → Settings → Developer Settings → OAuth Apps → Your App
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Only needed for local dev with `vercel dev`
# In production Vercel sets VERCEL_PROJECT_PRODUCTION_URL automatically
APP_URL=http://localhost:3000
